{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=db;Database=clubbooking;Username=postgres;Password=${POSTGRES_PASSWORD}"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "ClubBookingAPI",
    "Audience": "ClubBookingClient",
    "ExpiryMinutes": "60"
  },
  "AdminSecrets": {
    "Admin": "${ADMIN_SECRET}",
    "SuperAdmin": "${SUPER_ADMIN_SECRET}"
  },
  "AllowedHosts": "*"
}